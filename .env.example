# =============================================================================
# Secure Communication Platform — single .env file
# -----------------------------------------------------------------------------
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
#
#     cp .env.example .env
#     ${EDITOR:-nano} .env
#     docker compose up -d --build
#
# Every service runs in the single docker-compose.yml in this directory; there
# is NO secondary `jitsi/.env` file or separate compose project.
# =============================================================================


# ---- General ---------------------------------------------------------------
# Container time zone (used by Jitsi components and log timestamps).
TZ=UTC


# ---- Let's Encrypt / Certbot -----------------------------------------------
# Email used by Let's Encrypt for expiry notifications and account recovery.
LETSENCRYPT_EMAIL=admin@think-deploy.com


# ---- Rocket.Chat -----------------------------------------------------------
# Outgoing mail URL used for password reset, 2FA, invitations, etc.
# Format: smtps://USER:PASS@HOST:PORT/  or  smtp://USER:PASS@HOST:PORT/
# Leave blank to disable email features.
ROCKETCHAT_MAIL_URL=


# ---- SMTP (shared by Rocket.Chat OVERWRITE_SETTING_SMTP_* and Grafana) -----
SMTP_USERNAME=
SMTP_PASSWORD=


# ---- Grafana ---------------------------------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace-me-with-a-strong-password

# Optional Grafana SMTP alerting. Set GRAFANA_SMTP_ENABLED=true and provide
# SMTP_HOST plus SMTP_FROM_ADDRESS to enable email notifications.
GRAFANA_SMTP_ENABLED=false
SMTP_HOST=
SMTP_FROM_ADDRESS=


# ---- Jitsi -----------------------------------------------------------------
# Public IPv4 the JVB advertises in ICE candidates so remote browsers can reach
# UDP/10000 directly. REQUIRED on cloud / NAT environments.
JVB_ADVERTISE_IPS=

# Internal XMPP service-to-service passwords used by Prosody / Jicofo / JVB.
# These are *not* end-user credentials. Generate fresh values with, e.g.:
#   openssl rand -hex 16
JICOFO_AUTH_PASSWORD=replace-me-with-openssl-rand-hex-16
JICOFO_COMPONENT_SECRET=replace-me-with-openssl-rand-hex-16
JVB_AUTH_PASSWORD=replace-me-with-openssl-rand-hex-16

# Optional: set if you later enable Jibri (recording) or Jigasi (SIP).
JIBRI_RECORDER_PASSWORD=
JIBRI_XMPP_PASSWORD=
JIGASI_XMPP_PASSWORD=


# ---- Jitsi: Google OAuth -> JWT bridge -------------------------------------
# Joining a video call requires the user to sign in with Google. The auth-service
# container handles the OAuth flow under https://video.think-deploy.com/oauth/*
# and signs JWTs that Prosody accepts.
#
# Create a Web-application OAuth client at:
#   https://console.cloud.google.com/apis/credentials
# and set the **Authorized redirect URI** to:
#   https://video.think-deploy.com/oauth/google/callback
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
ALLOWED_GOOGLE_DOMAIN=yourdomain.com

# Symmetric secret used to sign and verify Jitsi JWTs (must be IDENTICAL on
# auth-service and Jitsi Prosody/Web). Generate with:
#   openssl rand -hex 48
JWT_SECRET=replace-me-with-openssl-rand-hex-48
# Alias for assignment checklists that expect this variable name.
JWT_APP_SECRET=${JWT_SECRET}

# JWT identity claims (defaults shown; override only if you reuse this stack
# for multiple tenants).
JWT_APP_ID=thinkdeploy
JWT_AUDIENCE=thinkdeploy
JWT_ISSUER=thinkdeploy
# Internal Jitsi XMPP domain — leave as default unless you re-template the
# upstream docker-jitsi-meet config files.
JWT_SUB=meet.jitsi
