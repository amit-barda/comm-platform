# =============================================================================
# Secure Communication Platform — root .env.example
# -----------------------------------------------------------------------------
# Copy this file to `.env` and fill in real values.  NEVER commit `.env`.
#
#     cp .env.example .env
#     ${EDITOR:-nano} .env
#     docker compose up -d --build
#
# Jitsi has its own environment file under ./jitsi/.env (see jitsi/.env.example).
# =============================================================================

# ---- Rocket.Chat ------------------------------------------------------------
# Public URL where Rocket.Chat is reachable through host Nginx + TLS.
ROCKETCHAT_ROOT_URL=https://chat.think-deploy.com
# Optional SMTP URL used by Rocket.Chat for outbound email (2FA, password reset, ...).
# Format: smtps://USER:PASS@HOST:PORT/  or  smtp://USER:PASS@HOST:PORT/
ROCKETCHAT_MAIL_URL=

# ---- Google OAuth (Auth Service -> JWT for Jitsi) ---------------------------
# Create a Web application credential in Google Cloud Console:
#   Authorized redirect URI: https://auth.think-deploy.com/auth/google/callback
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# ---- JWT (must match jitsi/.env JWT_APP_SECRET) -----------------------------
# Use a long random string (e.g. `openssl rand -hex 48`).
JWT_SECRET=replace-me-with-a-long-random-string

# Optional JWT claims (defaults shown). Must match jitsi/.env values.
# JWT_APP_ID=thinkdeploy
# JWT_AUDIENCE=thinkdeploy
# JWT_ISSUER=thinkdeploy
# JWT_SUB=meet.jitsi          # internal Jitsi XMPP domain — leave as default

# Public URLs used by the Auth Service (Google callback + Jitsi redirect target)
# AUTH_PUBLIC_BASE_URL=https://auth.think-deploy.com
# JITSI_PUBLIC_URL=https://video.think-deploy.com

# ---- Grafana ----------------------------------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace-me-with-a-strong-password
GRAFANA_ROOT_URL=https://grafana.think-deploy.com

# ---- SMTP (shared by Rocket.Chat and Grafana alerts) ------------------------
SMTP_USERNAME=
SMTP_PASSWORD=
# Optional Grafana-only knobs:
# GRAFANA_SMTP_ENABLED=true
# SMTP_HOST=smtp.example.com:587
# SMTP_FROM_ADDRESS=alerts@think-deploy.com
