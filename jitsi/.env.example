# ============================================================================
# Jitsi Meet (docker-jitsi-meet) — example environment variables
# ----------------------------------------------------------------------------
# Copy this file to `.env` inside this directory and edit. Do NOT commit `.env`.
# Reference: https://jitsi.github.io/handbook/docs/devops-guide/devops-guide-docker
#
# Only the values that are part of THIS deployment are documented here. The
# upstream `env.example` (vendored from docker-jitsi-meet) contains the full
# list of supported variables; consult it for advanced tweaks.
# ============================================================================

# ---- Local config path (created on first run) -------------------------------
# Use an absolute path on production hosts.
CONFIG=~/.jitsi-meet-cfg

# ---- HTTP/HTTPS ports exposed by the jitsi-web container --------------------
# Host Nginx terminates TLS and proxies https://video.think-deploy.com
# to http://127.0.0.1:8000 (HTTP_PORT below).
HTTP_PORT=8000
HTTPS_PORT=8443
TZ=UTC

# ---- Public URL ------------------------------------------------------------
# Must match the host Nginx server_name and the JWT `sub` claim.
PUBLIC_URL=https://video.think-deploy.com

# ---- JWT authentication ----------------------------------------------------
# These MUST match the values used by the auth-service that signs JWTs.
# JWT_APP_SECRET == auth-service JWT_SECRET (symmetric HMAC key, 97 chars
# recommended via `openssl rand -hex 48`).
ENABLE_AUTH=1
AUTH_TYPE=jwt
ENABLE_GUESTS=0

JWT_APP_ID=thinkdeploy
JWT_APP_SECRET=change-me-same-value-as-JWT_SECRET-in-auth-service
JWT_ACCEPTED_ISSUERS=thinkdeploy
JWT_ACCEPTED_AUDIENCES=thinkdeploy

# ---- Auto-redirect unauthenticated users to the OAuth bridge ----------------
# {room} is replaced by jitsi-meet web at click-time with the URL room name.
TOKEN_AUTH_URL=https://auth.think-deploy.com/auth/google?room={room}

# ---- Media (JVB) -----------------------------------------------------------
# REQUIRED on cloud VMs behind NAT. Set to the public IPv4 of the host so
# remote browsers can reach UDP/10000.
# JVB_ADVERTISE_IPS=203.0.113.10

# ---- Optional: letsencrypt inside Jitsi (NOT used here) --------------------
# We terminate TLS in the host Nginx, so leave these disabled.
# ENABLE_LETSENCRYPT=0
# LETSENCRYPT_DOMAIN=video.think-deploy.com
# LETSENCRYPT_EMAIL=admin@example.com
