# Copy to .env in this directory and adjust. Do not commit .env.
# Reference: https://jitsi.github.io/handbook/docs/devops-guide/devops-guide-docker

# Local config path (default from upstream; adjust to absolute path in production)
CONFIG=~/.jitsi-meet-cfg

HTTP_PORT=8000
HTTPS_PORT=8443
TZ=UTC

# JWT auth (must match the auth service JWT)
ENABLE_AUTH=1
AUTH_TYPE=jwt
ENABLE_GUESTS=0

JWT_APP_ID=thinkdeploy
JWT_APP_SECRET=change-me-same-value-as-JWT_SECRET-in-auth-service
JWT_ACCEPTED_ISSUERS=thinkdeploy
JWT_ACCEPTED_AUDIENCES=thinkdeploy

PUBLIC_URL=https://video.example.com

# Often required on cloud VMs: public IP of the host for JVB media
# JVB_ADVERTISE_IPS=x.x.x.x
