# ---- Secrets (never commit real env files) ---------------------------------
.env
**/.env
!.env.example
!**/.env.example

# Certificates / private keys
*.pem
*.key
*.crt
*.csr
*.p12

# ---- Dependencies / build output -------------------------------------------
node_modules/
**/node_modules/
npm-debug.log*
yarn-error.log*

# ---- Logs and runtime data --------------------------------------------------
*.log
logs/
data/
**/data/
tmp/
certbot/
letsencrypt/

# ---- Generated files (e.g. Rocket.Chat, build outputs) ----------------------
generated/
**/generated/
files/
**/files/

# ---- Local Jitsi state ------------------------------------------------------
**/.jitsi-meet-cfg/

# ---- OS / editor noise ------------------------------------------------------
.DS_Store
.idea/
.vscode/
*.swp
*~

# ---- Backups ----------------------------------------------------------------
*.save
*.bak
*.bak.*
compose.yml.bak

# ---- Cloudflare tunnels (if used) -------------------------------------------
.cloudflared/
/root/.cloudflared/

# ---- Large vendored artifacts ----------------------------------------------
*.tar.gz

# ---- Debug instrumentation (temporary) -------------------------------------
.debug/
