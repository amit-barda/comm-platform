{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "uid": "comm-platform-loki",
  "title": "Loki — Comm Platform Logs",
  "tags": ["loki", "logs", "comm-platform"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "weekStart": "",
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "templating": {
    "list": [
      {
        "type": "datasource",
        "name": "DS_LOKI",
        "label": "Loki",
        "query": "loki",
        "current": { "text": "Loki", "value": "loki" },
        "hide": 0,
        "refresh": 1,
        "regex": ""
      },
      {
        "type": "query",
        "name": "service",
        "label": "Service",
        "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
        "query": "label_values({job=\"docker\"}, service)",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "allValue": ".+",
        "current": { "text": "All", "value": "$__all" },
        "sort": 1
      },
      {
        "type": "textbox",
        "name": "search",
        "label": "Filter (regex)",
        "current": { "text": "", "value": "" },
        "query": "",
        "hide": 0
      }
    ]
  },
  "panels": [

    {
      "type": "stat",
      "id": 1,
      "title": "Log lines (selected range)",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "options": {
        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false },
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time({job=\"docker\", service=~\"$service\"} |~ \"(?i)$search\" [$__range]))",
          "queryType": "range"
        }
      ]
    },

    {
      "type": "stat",
      "id": 2,
      "title": "Error lines (selected range)",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "options": {
        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false },
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 10 },
              { "color": "red", "value": 100 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time({job=\"docker\", service=~\"$service\"} |~ \"(?i)(error|fatal|panic|exception|fail(ed)?)\" |~ \"(?i)$search\" [$__range]))",
          "queryType": "range"
        }
      ]
    },

    {
      "type": "stat",
      "id": 3,
      "title": "Active services",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "count(count by (service) (count_over_time({job=\"docker\", service=~\"$service\"} [$__range])))",
          "queryType": "instant"
        }
      ]
    },

    {
      "type": "stat",
      "id": 4,
      "title": "Lines / sec (now)",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 1,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate({job=\"docker\", service=~\"$service\"} |~ \"(?i)$search\" [1m]))",
          "queryType": "range"
        }
      ]
    },

    {
      "type": "timeseries",
      "id": 5,
      "title": "Log rate per service",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "fieldConfig": {
        "defaults": {
          "unit": "logs",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 1,
            "fillOpacity": 12,
            "stacking": { "mode": "normal", "group": "A" },
            "showPoints": "never"
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "right", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "legendFormat": "{{service}}",
          "expr": "sum by (service) (rate({job=\"docker\", service=~\"$service\"} |~ \"(?i)$search\" [$__interval]))",
          "queryType": "range"
        }
      ]
    },

    {
      "type": "timeseries",
      "id": 6,
      "title": "Error rate per service",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "fieldConfig": {
        "defaults": {
          "unit": "logs",
          "custom": {
            "drawStyle": "bars",
            "lineWidth": 0,
            "fillOpacity": 80,
            "showPoints": "never"
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "right", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "legendFormat": "{{service}}",
          "expr": "sum by (service) (rate({job=\"docker\", service=~\"$service\"} |~ \"(?i)(error|fatal|panic|exception|fail(ed)?)\" |~ \"(?i)$search\" [$__interval]))",
          "queryType": "range"
        }
      ]
    },

    {
      "type": "barchart",
      "id": 7,
      "title": "Top 10 services by log volume",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 13 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "showValue": "auto",
        "stacking": "none",
        "legend": { "showLegend": false, "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single", "sort": "none" },
        "xTickLabelRotation": 0
      },
      "targets": [
        {
          "refId": "A",
          "legendFormat": "{{service}}",
          "expr": "topk(10, sum by (service) (count_over_time({job=\"docker\", service=~\"$service\"} |~ \"(?i)$search\" [$__range])))",
          "queryType": "instant"
        }
      ]
    },

    {
      "type": "barchart",
      "id": 8,
      "title": "Top 10 services by errors",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 13 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red",   "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "showValue": "auto",
        "stacking": "none",
        "legend": { "showLegend": false, "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single", "sort": "none" },
        "xTickLabelRotation": 0
      },
      "targets": [
        {
          "refId": "A",
          "legendFormat": "{{service}}",
          "expr": "topk(10, sum by (service) (count_over_time({job=\"docker\", service=~\"$service\"} |~ \"(?i)(error|fatal|panic|exception|fail(ed)?)\" |~ \"(?i)$search\" [$__range])))",
          "queryType": "instant"
        }
      ]
    },

    {
      "type": "logs",
      "id": 9,
      "title": "Live logs (filtered)",
      "gridPos": { "h": 14, "w": 24, "x": 0, "y": 21 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{job=\"docker\", service=~\"$service\"} |~ \"(?i)$search\"",
          "queryType": "range",
          "maxLines": 1000
        }
      ]
    }
  ]
}
